rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────────────
    function isAuthed()  { return request.auth != null; }
    function role()      { return request.auth.token.role; }
    function isAdmin()   { return isAuthed() && role() == 'admin'; }
    function isStaff()   { return isAuthed() && (role() == 'staff' || role() == 'admin'); }

    // ── users (admin manages, each user reads own doc) ────────────────────
    match /users/{uid} {
      allow read:   if isAuthed() && (request.auth.uid == uid || isAdmin());
      allow write:  if isAdmin();
    }

    // ── reservations ─────────────────────────────────────────────────────
    match /reservations/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // ── appointments (staff scheduling) ──────────────────────────────────
    match /appointments/{id} {
      allow read:   if isStaff();
      allow write:  if isStaff();
    }

    // ── activity log (append-only for staff, read for staff) ─────────────
    match /activity/{id} {
      allow read:   if isStaff();
      allow create: if isStaff();
      allow update, delete: if false;
    }

    // ── daily capacity overrides ──────────────────────────────────────────
    match /dailyCapacity/{date} {
      allow read:   if isStaff();
      allow write:  if isAdmin();
    }

    // ── global settings ───────────────────────────────────────────────────
    match /settings/{doc} {
      allow read:   if isStaff();
      allow write:  if isAdmin();
    }
  }
}
